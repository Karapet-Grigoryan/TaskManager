@using TaskManager.BLL.DTOs
@using TaskManager.BLL.Enums
@model List<TaskDto>

@{
    ViewData["Title"] = "Tasks";
}

<div class="text-center">
    <h1 class="display-4">Tasks</h1>
</div>

<hr />

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Task</a>
</p>

<div class="mb-3">
    <input type="text" id="searchBox" class="form-control" placeholder="Search tasks..." />
</div>

<div id="taskTableContainer">

    @await Html.PartialAsync("_TaskTablePartial", Model)

</div>


@section Scripts
{
    <script src="~/js/task/index.js"></script>
}









